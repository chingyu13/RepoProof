# Copy this file to .env and fill in your key.
# Without a key, RepoProof runs in MOCK mode (deterministic sample questions).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional overrides
# REPOPROOF_MAX_MB=1024         # total PROJECT size limit at intake (MB)
# REPOPROOF_MAX_FILE_MB=1       # per-file analysis cap (MB); larger files skipped as evidence
# REPOPROOF_MAX_NOTEBOOK_MB=25  # per-file cap for .ipynb (outputs make them large)
# REPOPROOF_PORT=8000

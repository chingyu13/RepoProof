# Copy this file to .env and fill in your key.
# Without a key, RepoProof runs in MOCK mode (deterministic sample questions).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Creator login (required to use /creator and creator APIs)
REPOPROOF_ACCESS_PASSWORD=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REPOPROOF_SESSION_SECRET=

# Local LLM (privacy mode — no code leaves the machine). Any OpenAI-compatible
# server works. Install Ollama (https://ollama.com) then, WHILE ONLINE:
#   ollama pull qwen2.5-coder:7b
# Ollama serves at http://127.0.0.1:11434/v1 automatically.
# LM Studio alternative: http://127.0.0.1:1234/v1
# REPOPROOF_LOCAL_LLM_URL=http://127.0.0.1:11434/v1
# REPOPROOF_LOCAL_LLM_MODEL=qwen2.5-coder:7b
# REPOPROOF_LOCAL_LLM_MAX_TOKENS=700
# force default provider: openai | local | mock
# REPOPROOF_LLM_PROVIDER=local
# REPOPROOF_ASSESSMENT_CATALOG=/path/to/assessment_catalog.json

# Optional overrides
# total PROJECT size limit at intake (MB)
# REPOPROOF_MAX_MB=1024
# per-file analysis cap (MB); larger files skipped as evidence
# REPOPROOF_MAX_FILE_MB=1
# per-file cap for .ipynb (outputs make them large)
# REPOPROOF_MAX_NOTEBOOK_MB=25
# REPOPROOF_PORT=8000
